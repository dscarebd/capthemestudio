# ============================================================
# Lovable / TanStack SPA — Apache .htaccess (hardened)
# Place this file at the web root of your Apache hosting
# (e.g. public_html/) alongside index.html
# ============================================================

# ---------- Default document ----------
DirectoryIndex index.html

# ---------- Required for mod_rewrite on most shared hosts ----------
Options +FollowSymLinks -Indexes

# ---------- MIME types ----------
<IfModule mod_mime.c>
  AddType application/javascript            .js .mjs
  AddType text/css                          .css
  AddType image/svg+xml                     .svg .svgz
  AddType image/webp                        .webp
  AddType image/avif                        .avif
  AddType application/font-woff2            .woff2
  AddType application/font-woff             .woff
  AddType application/manifest+json         .webmanifest
  AddType application/json                  .json
</IfModule>

# ---------- Default charset ----------
AddDefaultCharset UTF-8

# ---------- Enable URL rewriting (SPA fallback) ----------
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Don't rewrite real files or directories
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Don't rewrite asset-like requests (let Apache return a real 404)
  RewriteRule \.(?:js|mjs|css|map|json|webmanifest|txt|xml|ico|png|jpe?g|gif|svg|webp|avif|woff2?|ttf|otf|eot|mp4|webm|mp3|wav|pdf)$ - [L]

  # SPA fallback — send everything else to index.html
  RewriteRule ^ /index.html [L]
</IfModule>

# ---------- Compression ----------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml \
    application/javascript application/json application/xml \
    application/rss+xml application/atom+xml image/svg+xml \
    font/woff font/woff2 application/font-woff application/font-woff2
</IfModule>

# ---------- Cache headers ----------
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML — never cache so users always get the newest deployment
  ExpiresByType text/html                          "access plus 0 seconds"

  # Hashed assets (Vite output) — cache aggressively
  ExpiresByType application/javascript             "access plus 1 year"
  ExpiresByType text/css                           "access plus 1 year"
  ExpiresByType image/svg+xml                      "access plus 1 year"
  ExpiresByType image/webp                         "access plus 1 year"
  ExpiresByType image/avif                         "access plus 1 year"
  ExpiresByType image/png                          "access plus 1 year"
  ExpiresByType image/jpeg                         "access plus 1 year"
  ExpiresByType image/gif                          "access plus 1 year"
  ExpiresByType image/x-icon                       "access plus 1 year"
  ExpiresByType font/woff                          "access plus 1 year"
  ExpiresByType font/woff2                         "access plus 1 year"
  ExpiresByType application/font-woff              "access plus 1 year"
  ExpiresByType application/font-woff2             "access plus 1 year"
  ExpiresByType application/manifest+json          "access plus 1 week"
</IfModule>

<IfModule mod_headers.c>
  # Long-lived cache for hashed assets
  <FilesMatch "\.(js|mjs|css|woff2?|ttf|otf|eot|svg|webp|avif|png|jpe?g|gif|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Always revalidate HTML
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # Basic security headers
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# ---------- Final fallback: if mod_rewrite is OFF, 404s still load the SPA ----------
ErrorDocument 403 /index.html
ErrorDocument 404 /index.html
